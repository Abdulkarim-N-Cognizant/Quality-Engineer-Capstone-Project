		{
			"name": "GET Posts by userId",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"\r",
							"let json = pm.response.json();\r",
							"\r",
							"pm.test(\"All posts belong to user 1\", function () {\r",
							"    json.forEach(post => {\r",
							"        pm.expect(post.userId).to.eql(1);\r",
							"    });\r",
							"});\r",
							""
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "https://jsonplaceholder.typicode.com/posts?userId=1",
					"protocol": "https",
					"host": [
						"jsonplaceholder",
						"typicode",
						"com"
					],
					"path": [
						"posts"
