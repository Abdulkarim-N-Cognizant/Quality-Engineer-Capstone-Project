	"item": [
		{
			"name": "Get All Posts",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response is a list\", function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json).to.be.an(\"array\");",
							"});",
							"",
							"pm.test(\"Post has required fields\", function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json[0]).to.have.property(\"id\");",
							"    pm.expect(json[0]).to.have.property(\"title\");",
							"    pm.expect(json[0]).to.have.property(\"body\");",
							"    pm.expect(json[0]).to.have.property(\"userId\");",
							"});",
							"",
							"pm.test(\"Response time is less than 2000ms\", function () {",
							"    pm.expect(pm.response.responseTime).to.be.below(2000);",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				},
				{
					"listen": "prerequest",
