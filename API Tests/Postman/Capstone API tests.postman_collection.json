		{
			"name": "Post data",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Successful POST request\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([201]);",
							"});",
							"",
							"pm.test(\"Post has required fields\", function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json).to.have.property(\"id\");",
							"    pm.expect(json).to.have.property(\"title\");",
							"    pm.expect(json).to.have.property(\"body\");",
							"    pm.expect(json).to.have.property(\"userId\");",
							"});",
							"",
							"",
							"pm.test(\"Response matches request body\", function () {",
							"    const requestBody = JSON.parse(pm.request.body.raw);",
							"    const response = pm.response.json();",
							"",
							"    pm.expect(response.title).to.eql(requestBody.title);",
							"    pm.expect(response.body).to.eql(requestBody.body);",
							"    pm.expect(response.userId).to.eql(requestBody.userId);",
							"});",
							"",
							"",
							"pm.test(\"Response time is less than 200ms\", function () {",
							"    pm.expect(pm.response.responseTime).to.be.below(200);",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
